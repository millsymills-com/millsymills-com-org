# Tofu
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
.terraform/
.terraform.lock.hcl.local
crash.log

# Module-level lockfiles: root .terraform.lock.hcl is tracked for reproducible
# CI builds; per-module locks are dev-only artifacts (CI re-inits per workflow).
modules/**/.terraform.lock.hcl

# Secrets / local
*.pem
*.key
.env
.env.*
bootstrap/*.local.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Tofu plan artifacts
tfplan
*.tfplan
plan.out
